{{!< default}}
{{#contentFor "head"}}
    <meta property="og:title" content="{{meta_title}}">
    <meta property="og:description" content="{{meta_description}}">
    {{#if @site.cover_image}}
        <meta property="og:image" content="{{img_url @site.cover_image size="l" absolute="true"}}">
    {{else}}
        <meta property="og:image" content="{{@site.url}}/assets/images/fallback/post-default.png">
    {{/if}}
    <link rel="canonical" href="{{url absolute="true"}}">
{{/contentFor}}

<div class="gh-outer">
<main class="site-main gh-inner search-page">
    <section class="term search-term">
        <h1 class="term-name">Search</h1>
        <div class="term-description">Quickly find posts by title and excerpt.</div>
    </section>

    <section class="search-shell" aria-label="Search posts by title and excerpt">
        <form class="search-form" role="search" novalidate>
            <label class="search-label" for="search-input">Query</label>
            <div class="search-input-row">
                <input id="search-input" class="search-input" type="search" name="q" autocomplete="off" placeholder="Search titles and excerpts" />
                <button class="search-submit gh-btn" type="submit">Search</button>
            </div>
            <p id="search-state" class="search-state" aria-live="polite">Search titles and excerpts (2+ characters).</p>
        </form>
    </section>

    <section class="search-results-wrap" aria-label="Search results">
        <div id="search-results" class="post-feed gh-feed js-promo-feed"></div>
        <nav id="search-pagination" class="ayu-pagination search-pagination" aria-label="Search pagination"></nav>
    </section>
</main>
</div>

