{{!< default}}

<div class="gh-outer">
<main class="site-main gh-inner explore-page">
    <section class="term term-tag-header explore-header">
        <h1 class="term-name">Explore</h1>
        <div class="term-description">Discover categories, series, topics and writing.</div>
    </section>

    <nav class="explore-quick-links" aria-label="Explore sections">
        <a href="#explore-categories">Categories</a>
        <a href="#explore-series">Series</a>
        <a href="#explore-topics">Topics</a>
        <a href="#explore-recent">Recent</a>
    </nav>

    <section id="explore-categories" class="explore-section" aria-label="Categories">
        <h2 class="explore-section-title">Categories</h2>
        <div id="explore-categories-grid" class="explore-grid explore-grid-two"></div>
    </section>

    <section id="explore-series" class="explore-section" aria-label="Series">
        <h2 class="explore-section-title">Series</h2>
        <div id="explore-series-list" class="explore-series-list"></div>
    </section>

    <section id="explore-topics" class="explore-section" aria-label="Topics">
        <h2 class="explore-section-title">Topics</h2>
        <div id="explore-topics-grid" class="explore-grid explore-grid-two explore-topics-grid"></div>
    </section>

    <section id="explore-recent" class="explore-section" aria-label="Recent posts">
        <h2 class="explore-section-title">Recent posts</h2>
        <ul id="explore-recent-list" class="explore-recent-list"></ul>
    </section>
</main>
</div>
