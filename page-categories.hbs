{{!< default}}
{{#contentFor "head"}}
    <meta property="og:title" content="{{meta_title}}">
    <meta property="og:description" content="{{meta_description}}">
    {{#if @site.cover_image}}
        <meta property="og:image" content="{{img_url @site.cover_image size="l" absolute="true"}}">
    {{else}}
        <meta property="og:image" content="{{@site.url}}/assets/images/fallback/post-default.png">
    {{/if}}
    <link rel="canonical" href="{{url absolute="true"}}">
{{/contentFor}}

<div class="gh-outer">
<main class="site-main gh-inner">
    <section class="term term-tag-header">
        <div class="tag-header-image-wrap">
            <img class="tag-header-image" src="{{asset "images/hub/categories-hero.png"}}" alt="Categories">
        </div>
        <h1 class="term-name">Categories</h1>
        <div class="term-description">Explore posts organized by topic.</div>
    </section>

    
    <section class="category-hub-links" aria-label="Additional hubs">
        <a class="category-hub-link" href="{{@site.url}}/secondary-tags/">
            <span class="category-hub-link-title">Topics</span>
            <span class="category-hub-link-description">Browse topics beyond categories and series.</span>
        </a>
    </section>

    <section class="category-featured" aria-label="Featured category">
        <h2 class="category-featured-title">Featured category</h2>
        <div id="primary-featured-grid" class="post-feed gh-feed"></div>
    </section>

    <section class="category-post-list" aria-label="Categories list">
        <h2 class="category-post-list-title">All categories</h2>
        <div id="primary-list-grid" class="post-feed gh-feed js-promo-feed"></div>
    </section>

    <nav id="primary-list-pagination" class="ayu-pagination" aria-label="Categories pagination"></nav>
</main>
</div>


