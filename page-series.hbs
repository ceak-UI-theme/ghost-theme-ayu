{{!< default}}

<div class="gh-outer">
<main class="site-main gh-inner">
    <section id="series-list-header" class="term term-tag-header">
        <div class="tag-header-image-wrap">
            <img class="tag-header-image" src="{{asset "images/hub/series-hero.png"}}" alt="Series">
        </div>
        <h1 class="term-name">Series</h1>
        <div class="term-description">Collections of long-form essays and themed series.</div>
    </section>

    <section id="series-list-featured" class="category-featured" aria-label="Featured series">
        <h2 class="category-featured-title">Featured series</h2>
        <div id="series-featured-grid" class="post-feed gh-feed"></div>
    </section>

    <section id="series-list-all" class="category-post-list" aria-label="Series list">
        <h2 class="category-post-list-title">All series</h2>
        <div id="series-list-grid" class="post-feed gh-feed js-promo-feed"></div>
    </section>

</main>
</div>

