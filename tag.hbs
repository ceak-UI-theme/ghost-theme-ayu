{{!< default}}
{{#contentFor "head"}}
    <meta property="og:title" content="{{tag.name}}">
    {{#if tag.description}}
        <meta property="og:description" content="{{tag.description}}">
    {{else}}
        <meta property="og:description" content="{{@site.description}}">
    {{/if}}
    {{#if tag.feature_image}}
        <meta property="og:image" content="{{img_url tag.feature_image size="l" absolute="true"}}">
    {{else}}
        {{#if @site.cover_image}}
            <meta property="og:image" content="{{img_url @site.cover_image size="l" absolute="true"}}">
        {{else}}
            <meta property="og:image" content="{{@site.url}}/assets/images/fallback/post-default.png">
        {{/if}}
    {{/if}}
    <link rel="canonical" href="{{url absolute="true"}}">
{{/contentFor}}

<div class="gh-outer">
<main class="site-main gh-inner">

    <section class="term term-tag-header">
        {{#if tag.feature_image}}
            <div class="tag-header-image-wrap">
                <img class="tag-header-image" src="{{img_url tag.feature_image size="l"}}" alt="{{tag.name}}">
            </div>
        {{/if}}
        <h1 class="term-name" data-tag-slug="{{tag.slug}}">{{tag.name}}</h1>
        {{#if tag.description}}
            <div class="term-description">{{tag.description}}</div>
        {{/if}}
    </section>

    {{#get "posts" filter="tag:{{tag.slug}}+featured:true" include="tags,authors" limit="1"}}
        {{#if posts}}
            <section class="tag-featured" aria-label="Featured post">
                <h2 class="tag-featured-title">Featured post</h2>
                <div class="post-feed gh-feed">
                    {{#foreach posts limit="1"}}
                        {{> "loop"}}
                    {{/foreach}}
                </div>
            </section>

            <section class="tag-post-list" aria-label="Post list">
                <h2 class="tag-post-list-title">Latest posts</h2>
                <div class="post-feed gh-feed js-promo-feed">
                    {{#foreach ../posts}}
                        {{#unless featured}}
                            {{> "loop"}}
                        {{/unless}}
                    {{/foreach}}
                </div>
            </section>

            {{pagination}}
        {{else}}
            <section class="tag-featured" aria-label="Featured post">
                <h2 class="tag-featured-title">Featured post</h2>
                <div class="post-feed gh-feed">
                    {{#foreach ../posts limit="1"}}
                        {{> "loop"}}
                    {{/foreach}}
                </div>
            </section>

            <section class="tag-post-list" aria-label="Post list">
                <h2 class="tag-post-list-title">Latest posts</h2>
                <div class="post-feed gh-feed js-promo-feed">
                    {{#foreach ../posts from="2"}}
                        {{> "loop"}}
                    {{/foreach}}
                </div>
            </section>

            {{pagination}}
        {{/if}}
    {{/get}}

</main>
</div>

