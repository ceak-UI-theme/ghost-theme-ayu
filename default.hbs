<!DOCTYPE html>
<html lang="{{@site.locale}}" data-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem('theme-preference');
                var nextTheme = savedTheme === 'dark' ? 'dark' : 'light';
                var root = document.documentElement;

                root.setAttribute('data-theme', nextTheme);
                root.classList.toggle('theme-dark', nextTheme === 'dark');
            } catch (error) {
                // Ignore storage access errors and keep default theme.
            }
        }());
    </script>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">

    {{ghost_head}}
    {{{block "head"}}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-head-{{#match @custom.navigation_layout "Logo on the left"}}left-logo{{else match @custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}">
<div class="site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="{{@site.url}}">
                        {{#if @site.logo}}
                            <img src="{{@site.logo}}" alt="{{@site.title}}">
                        {{else}}
                            {{@site.title}}
                        {{/if}}
                    </a>
                </div>
                <a class="gh-search gh-icon-btn" aria-label="Search page" href="{{@site.url}}/search/">{{> "icons/search"}}</a>
                <button class="gh-burger" aria-label="Toggle menu"></button>
            </div>

            <nav class="gh-head-menu">
                <div class="gh-head-menu-group">
                    {{navigation}}
                    <ul class="nav nav-extra">
                        <li class="nav-explore"><a href="{{@site.url}}/explore/">Explore</a></li>
                        <li class="nav-categories"><a href="{{@site.url}}/categories/">Categories</a></li>
                        <li class="nav-series"><a href="{{@site.url}}/series/">Series</a></li>
                    </ul>
                </div>
                {{#unless @site.members_enabled}}
                    {{#match @custom.navigation_layout "Stacked"}}
                        <a class="gh-search gh-icon-btn" aria-label="Search page" href="{{@site.url}}/search/">{{> "icons/search"}}</a>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                <button class="gh-head-link gh-theme-toggle js-theme-toggle" type="button" aria-pressed="false">Theme</button>
                {{#unless @site.members_enabled}}
                    {{^match @custom.navigation_layout "Stacked"}}
                        <a class="gh-search gh-icon-btn" aria-label="Search page" href="{{@site.url}}/search/">{{> "icons/search"}}</a>
                    {{/match}}
                {{else}}
                    <a class="gh-search gh-icon-btn" aria-label="Search page" href="{{@site.url}}/search/">{{> "icons/search"}}</a>
                    <div class="gh-head-members">
                        {{#unless @member}}
                            {{#unless @site.members_invite_only}}
                                <a class="gh-head-link" href="#/portal/signin" data-portal="signin">Sign in</a>
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signup" data-portal="signup">Subscribe</a>
                            {{else}}
                                <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/signin" data-portal="signin">Sign in</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-btn gh-btn gh-primary-btn" href="#/portal/account" data-portal="account">Account</a>
                        {{/unless}}
                    </div>
                {{/unless}}
            </div>
        </div>
    </header>

    {{#is "home"}}
    {{#if @site.cover_image}}
        <div class="site-cover u-overlay">
            <img class="cover-image u-object-fit" src="{{img_url @site.cover_image}}" alt="{{@site.title}}">
            <div class="cover-content">
                {{#if @site.logo}}
                    <img class="cover-logo" src="{{@site.logo}}" alt="{{@site.title}}">
                {{/if}}
                {{#if @site.description}}
                    <div class="cover-description">{{@site.description}}</div>
                {{/if}}
            </div>
        </div>
    {{/if}}
    {{/is}}

    <div class="site-content">
        {{{body}}}
    </div>

    <footer class="gh-foot gh-outer">
        <div class="gh-foot-inner gh-inner">
            <div class="subscribe{{#if is_popup}} popup{{/if}}">
                <a href="{{#if @custom.rss_link}}{{@custom.rss_link}}{{else}}{{@site.url}}/rss{{/if}}" class="subscribe-link rss" target="_blank" rel="noopener noreferrer">
                    {{> "icons/rss"}}
                    <span class="subscribe-text">RSS</span>
                </a>
                {{#if @custom.github_link}}
                    <a href="{{@custom.github_link}}" class="subscribe-link" target="_blank" rel="noopener noreferrer">
                        {{> "icons/github"}}
                        <span class="subscribe-text">GitHub</span>
                    </a>
                {{/if}}
                {{#if @custom.twitter_x_link}}
                    <a href="{{@custom.twitter_x_link}}" class="subscribe-link" target="_blank" rel="noopener noreferrer">
                        {{> "icons/twitter"}}
                        <span class="subscribe-text">X (Twitter)</span>
                    </a>
                {{/if}}
                {{#if @custom.linkedin_link}}
                    <a href="{{@custom.linkedin_link}}" class="subscribe-link" target="_blank" rel="noopener noreferrer">
                        {{> "icons/linkedin"}}
                        <span class="subscribe-text">LinkedIn</span>
                    </a>
                {{/if}}
            </div>
            <nav class="gh-foot-menu">
                {{navigation type="secondary"}}
            </nav>
            <div class="gh-copyright">
                &copy; {{date format="YYYY"}} {{@site.title}}<br>
                Built with Ghost &middot; Theme customized by Ceak
            </div>
        </div>
    </footer>

</div>

<script id="ayu-content-key" data-key="{{@site.content_api_key}}"></script>
<script src="{{asset "built/main.min.js"}}"></script>

{{{block "scripts"}}}

{{ghost_foot}}

</body>
</html>
