{{!< default}}

{{#post}}
{{#contentFor "head"}}
    <meta property="og:title" content="{{title}}">
    {{#if custom_excerpt}}
        <meta property="og:description" content="{{custom_excerpt}}">
    {{else}}
        {{#if excerpt}}
            <meta property="og:description" content="{{excerpt}}">
        {{else}}
            <meta property="og:description" content="{{@site.description}}">
        {{/if}}
    {{/if}}
    {{#if feature_image}}
        <meta property="og:image" content="{{img_url feature_image size="l" absolute="true"}}">
    {{else}}
        {{#if @site.cover_image}}
            <meta property="og:image" content="{{img_url @site.cover_image size="l" absolute="true"}}">
        {{else}}
            <meta property="og:image" content="{{@site.url}}/assets/images/fallback/post-default.png">
        {{/if}}
    {{/if}}
    <link rel="canonical" href="{{url absolute="true"}}">
{{/contentFor}}

<main class="site-main">
    <article class="{{post_class}} single" data-taxonomy-model="slug-prefix">
        <header class="post-header gh-canvas">
            {{> "post-meta" show_width_toggle=true}}
            <h1 class="post-title">{{title}}</h1>
            {{> "feature-image"}}
        </header>

        <section class="gh-canvas post-audio" data-post-audio data-slug="{{slug}}" data-title="{{title}}" hidden></section>

        <div class="post-content gh-content gh-canvas">
            {{content}}
        </div>

        {{#if @custom.adsense_client}}
            {{#if @custom.ad_slot_post_bottom}}
                <div class="gh-canvas post-ad-slot-wrap post-ad-slot-wrap--bottom">
                    <aside class="post-ad-slot js-ad-slot ayu-ad-slot ayu-ad-slot--post-bottom" data-ad-slot="post-bottom">
                    </aside>
                </div>
            {{/if}}
        {{/if}}

        <aside class="post-toc" aria-label="On this page" hidden></aside>

        <div class="gh-canvas post-bottom-navigation">
            {{> "series-navigation"}}
            {{> "post-navigation"}}
        </div>

        <div class="gh-canvas">
            <div class="author-list">
                <h3 class="author-list-title">Written by:</h3>
                {{#foreach authors}}
                    {{> "author-box"}}
                {{/foreach}}
            </div>
            {{#if comments}}
                <section class="gh-comments">
                    <header class="gh-comments-header">
                        <h3 class="gh-comments-title author-list-title">Member discussion:</h3>
                        {{comment_count class="gh-comments-count"}}
                    </header>
                    {{comments title="" count=false}}
                </section>
            {{/if}}
        </div>

    </article>
</main>

{{/post}}




