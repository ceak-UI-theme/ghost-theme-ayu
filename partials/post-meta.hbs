<div class="post-meta">
    <div class="post-meta-primary">
        <span class="post-meta-item post-meta-date">
            <time datetime="{{date format="YYYY-MM-DD"}}">
                {{date format="YYYY.MM.DD"}}
            </time>
            <span aria-hidden="true"> · </span>
            <span class="post-reading-time">{{reading_time minute="1 min read" minutes="% min read"}}</span>
        </span>
        {{#if tags}}
            <span class="post-meta-item post-meta-tags">
                {{#foreach tags}}
                    {{#match visibility "public"}}
                        {{!--
                            Ghost Handlebars does not provide a reliable startsWith helper in theme templates.
                            Taxonomy role detection uses `match "~"` (substring match), so slug naming rules must stay strict:
                            - category-* and series-* are reserved prefixes
                            - avoid embedding `category-` or `series-` in the middle of unrelated slugs
                        --}}
                        <a
                            class="post-tag post-tag-{{slug}} {{#match slug "~" "category-"}}is-primary-tag tag-category{{else match slug "~" "series-"}}is-series-tag tag-series{{else}}is-secondary-tag tag-topic{{/match}}"
                            data-tag-slug="{{slug}}"
                            data-tag-name="{{name}}"
                            data-tag-visibility="{{visibility}}"
                            data-taxonomy-role="{{#match slug "~" "category-"}}category{{else match slug "~" "series-"}}series{{else}}topic{{/match}}"
                            data-taxonomy-rendered="server"
                            href="{{url}}"
                            title="{{name}}"
                        >{{name}}</a>
                    {{/match}}
                {{/foreach}}
            </span>
        {{/if}}
    </div>
    {{#if show_width_toggle}}
        <div class="reading-width-toggle js-reading-width-toggle" role="group" aria-label="Reading width">
            <span class="reading-width-label">Width</span>
            <button class="reading-width-btn" type="button" data-width-mode="normal" aria-pressed="true">Normal</button>
            <button class="reading-width-btn" type="button" data-width-mode="wide" aria-pressed="false">Wide</button>
            <button class="reading-width-btn" type="button" data-width-mode="expanded" aria-pressed="false">Expanded</button>
        </div>
    {{/if}}
</div>
