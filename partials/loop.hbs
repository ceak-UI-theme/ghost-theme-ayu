<article class="{{post_class}}" data-id="{{comment_id}}" data-slug="{{slug}}">
    <div class="post-media">
        <div class="u-placeholder square">
            <a href="{{url}}">
                {{#if feature_image}}
                    <img class="post-image lazyload u-object-fit" src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
                {{else}}
                    <img class="post-image lazyload u-object-fit" src="{{asset "images/fallback/post-default.png"}}" alt="{{title}}">
                {{/if}}
            </a>
        </div>
        <div class="post-media-badges" data-post-badge-row aria-hidden="true"></div>
    </div>
    <div class="post-wrapper">
        <header class="post-header">
            {{> "post-meta"}}
            <h2 class="post-title">
                <a class="post-title-link" href="{{url}}">{{title}}</a>
            </h2>
        </header>
        {{#if excerpt}}
            <div class="post-excerpt">
                {{excerpt words="25"}}
            </div>
        {{/if}}
    </div>
</article>
