<nav class="post-global-nav" aria-label="Post navigation">
    {{#prev_post}}
        <a class="post-global-nav-link is-prev" href="{{url}}">
            <span class="post-global-nav-label">Previous Post</span>
            <span class="post-global-nav-title">{{title}}</span>
        </a>
    {{/prev_post}}

    {{#next_post}}
        <a class="post-global-nav-link is-next" href="{{url}}">
            <span class="post-global-nav-label">Next Post</span>
            <span class="post-global-nav-title">{{title}}</span>
        </a>
    {{/next_post}}
</nav>
