{{!< default}}
{{#contentFor "head"}}
    <meta property="og:title" content="{{meta_title}}">
    <meta property="og:description" content="{{meta_description}}">
    {{#if @site.cover_image}}
        <meta property="og:image" content="{{img_url @site.cover_image size="l" absolute="true"}}">
    {{else}}
        <meta property="og:image" content="{{@site.url}}/assets/images/fallback/post-default.png">
    {{/if}}
    <link rel="canonical" href="{{url absolute="true"}}">
{{/contentFor}}

<div class="gh-outer">
<main class="site-main gh-inner">
    <section class="term">
        <h1 class="term-name">Topics</h1>
        <div class="term-description">Explore supporting topics across the site.<br>Browse topics beyond categories and series.</div>
    </section>

    <section id="secondary-tags-featured" class="term term-tag-header secondary-tags-featured" hidden></section>

    <section class="category-post-list secondary-tags-list" aria-label="Topics list">
        <h2 class="category-post-list-title">All topics</h2>
        <div id="secondary-tags-grid" class="secondary-tags-grid"></div>
    </section>

</main>
</div>

