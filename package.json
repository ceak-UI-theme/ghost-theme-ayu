{
    "name": "signal-wave-ayu",
    "description": "Signal Wave Ayu Ghost theme",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "ghost": ">=5.0.0"
    },
    "license": "MIT",
    "author": {
        "name": "ceak",
        "email": "ceak@example.com",
        "url": "https://github.com/ceak-UI-theme"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ceak-UI-theme/ghost-theme-ayu.git"
    },
    "keywords": [
        "ghost",
        "theme",
        "ghost-theme"
    ],
    "docs": "https://github.com/ceak-UI-theme/ghost-theme-ayu",
    "config": {
        "posts_per_page": 10,
        "image_sizes": {
            "xs": {
                "width": 150
            },
            "s": {
                "width": 300
            },
            "m": {
                "width": 720
            },
            "l": {
                "width": 960
            },
            "xl": {
                "width": 1200
            },
            "xxl": {
                "width": 2000
            }
        },
        "card_assets": true,
        "custom": {
            "adsense_client": {
                "type": "text",
                "group": "AdSense",
                "title": "AdSense Client ID",
                "description": "Publisher ID (e.g. ca-pub-xxxxxxxxxxxxxxxx)"
            },
            "ad_slot_list_inline": {
                "type": "text",
                "group": "AdSense",
                "title": "List Inline Ad Slot ID",
                "description": "Slot ID for list/feed inline ads"
            },
            "ad_slot_post_mid": {
                "type": "text",
                "group": "AdSense",
                "title": "Post Mid Ad Slot ID",
                "description": "Slot ID for mid-content post ads"
            },
            "ad_slot_post_bottom": {
                "type": "text",
                "group": "AdSense",
                "title": "Post Bottom Ad Slot ID",
                "description": "Slot ID for bottom-of-post ads"
            },
            "navigation_layout": {
                "type": "select",
                "options": [
                    "Logo on the left",
                    "Logo in the middle",
                    "Stacked"
                ],
                "default": "Logo on the left"
            },
            "title_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Modern sans-serif"
            },
            "body_font": {
                "type": "select",
                "options": [
                    "Modern sans-serif",
                    "Elegant serif"
                ],
                "default": "Modern sans-serif"
            },
            "github_link": {
                "type": "text",
                "default": "https://github.com/"
            },
            "twitter_x_link": {
                "type": "text",
                "default": "https://x.com/{username}"
            },
            "linkedin_link": {
                "type": "text",
                "default": "https://www.linkedin.com/"
            },
            "rss_link": {
                "type": "text"
            }
        }
    },
    "scripts": {
        "dev": "gulp",
        "test": "gscan .",
        "zip": "gulp zip",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tryghost/shared-theme-assets": "2.5.2",
        "autoprefixer": "10.4.27",
        "beeper": "2.1.0",
        "cssnano": "7.1.2",
        "gscan": "5.2.5",
        "gulp": "5.0.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.8",
        "postcss-easy-import": "4.0.0",
        "prismjs": "^1.30.0",
        "pump": "3.0.4"
    }
}
