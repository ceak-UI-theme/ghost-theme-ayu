{{!< default}}

<div class="gh-outer">
<main class="site-main gh-inner">
    <section class="term term-tag-header">
        <div class="tag-header-image-wrap">
            <img class="tag-header-image" src="{{asset "images/hub/categories-hero.png"}}" alt="Categories">
        </div>
        <h1 class="term-name">Categories</h1>
        <div class="term-description">Explore posts organized by topic.</div>
    </section>

    
    <section class="category-hub-links" aria-label="Additional hubs">
        <a class="category-hub-link" href="/categories/">
            <span class="category-hub-link-title">Categories</span>
            <span class="category-hub-link-description">Browse primary categories and featured taxonomy.</span>
        </a>
    </section>

    <section class="category-featured" aria-label="Featured category">
        <h2 class="category-featured-title">Featured category</h2>
        <div id="primary-featured-grid" class="post-feed gh-feed"></div>
    </section>

    <section class="category-post-list" aria-label="Categories list">
        <h2 class="category-post-list-title">All primary categories</h2>
        <div id="primary-list-grid" class="post-feed gh-feed js-promo-feed"></div>
    </section>
</main>
</div>
